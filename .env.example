# MakerChecker server environment. Copy to .env and adjust.
# Every variable is optional except DATABASE_URL.

# --- Core ---

# Postgres connection string. Required to start the server or run the CLI.
DATABASE_URL=postgres://makerchecker:makerchecker@localhost:5432/makerchecker

# HTTP port the API and web UI listen on. Default: 3000.
PORT=3000

# Comma-separated origins allowed for browser cross-origin requests. Empty (the
# default) emits no CORS allow-origin header, so browsers block cross-origin reads.
ALLOWED_ORIGINS=

# --- Model executor ---
# With no API key the server runs the scripted executor (deterministic, air-gapped).
# Setting a key switches agent steps to that provider unless MAKERCHECKER_EXECUTOR=scripted.

# Anthropic API key. When set, the default model is claude-opus-4-8.
ANTHROPIC_API_KEY=

# Gemini API key (OpenAI-compatible endpoint). When set, the default model is
# gemini-3-flash-preview. ANTHROPIC_API_KEY takes precedence if both are set.
GEMINI_API_KEY=

# Override the default model id for whichever provider is selected.
MAKERCHECKER_MODEL=

# Force the scripted (deterministic) executor even when an API key is present.
# Set to "scripted" to opt out of live model calls.
MAKERCHECKER_EXECUTOR=

# --- Demo seeding ---

# Set to 1 to seed the demo agents, flows, and admin/officer accounts at boot.
# Unset seeds nothing.
MAKERCHECKER_SEED_DEMO=

# Root directory the demo ingest skills are allowed to read from.
DEMO_DATA_DIR=examples/daily-cash-reconciliation

# --- Storage ---

# Directory holding the instance Ed25519 keypair (instance_key.pem, mode 0600).
# Default: ./data.
MAKERCHECKER_DATA_DIR=./data

# --- Boot / local-only switches ---

# Set to 1 to skip running migrations at boot. Default unset = run migrations.
MAKERCHECKER_SKIP_MIGRATE=

# Set to 1 to disable API key auth entirely. Local demos only; the server
# refuses to start with this on unless it binds loopback (127.0.0.1 / ::1 /
# localhost). Default unset = auth on.
MAKERCHECKER_AUTH_DISABLED=

# --- Segregation of duties ---

# Set to 1 to require every approval gate to be identity-mode (forbid_requester
# not disabled): publishing rejects a self-approvable gate, and the run's own
# requester (admin included) is denied at decision time even on a legacy gate.
# Default unset = legacy gates keep their existing behavior.
MAKERCHECKER_REQUIRE_IDENTITY_GATES=

# --- Skill execution hardening ---

# Comma-separated allowlist of exact commands MCP stdio skills may spawn. Unset
# falls back to the secure deny-list default; set this in production to pin stdio
# skills to a known set of commands.
MAKERCHECKER_STDIO_ALLOWED_COMMANDS=

# Set to 1 to allow HTTP/MCP skills to reach private and loopback hosts. Off by
# default (SSRF egress guard). Production never sets this.
MAKERCHECKER_ALLOW_PRIVATE_SKILL_HOSTS=
