{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["TEST_DATABASE_URL", "PG_BIN", "DATABASE_URL", "MAKERCHECKER_DATA_DIR"],
  "tasks": {
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    }
  }
}
