    "lint": "eslint src",
    "test": "vitest run --coverage",
    "dev": "vite"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
