{
  "name": "@makerchecker/web",
  "version": "1.0.0",
  "description": "MakerChecker web console: Vite/React SPA for roles, grants, approvals, runs, and audit verification.",
  "license": "AGPL-3.0-only",
  "author": "Mashini Investments Ltd. <hello@makerchecker.ai>",
  "homepage": "https://makerchecker.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sammysltd/makerchecker.git",
    "directory": "packages/web"
  },
  "bugs": "https://github.com/sammysltd/makerchecker/issues",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
