        "operationId": "createRole",
        "tags": [
          "roles"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "limits": {
                    "additionalProperties": false,
                    "type": "object",
                    "properties": {
                      "run": {
                        "additionalProperties": false,
                        "type": "object",
                        "properties": {
                          "maxSkillInvocations": {
                            "minimum": 0,
                            "type": "integer"
                          },
                          "maxTokens": {
                            "minimum": 0,
                            "type": "integer"
                          }
                        }
                      },
                      "skills": {
                        "additionalProperties": {
                          "additionalProperties": false,
                          "type": "object",
                          "properties": {
                            "maxInvocationsPerRun": {
                              "minimum": 0,
                              "type": "integer"
                            },
                            "maxAmountPerInvocation": {
                              "minimum": 0,
                              "type": "number"
                            },
                            "amountField": {
                              "minLength": 1,
                              "type": "string"
                            },
                            "allowlist": {
                              "additionalProperties": false,
                              "type": "object",
                              "required": [
                                "field",
                                "values"
                              ],
                              "properties": {
                                "field": {
                                  "minLength": 1,
                                  "type": "string"
                                },
                                "values": {
                                  "minItems": 1,
                                  "type": "array",
                                  "items": {
                                    "minLength": 1,
                                    "type": "string"
                                  }
                                }
                              }
                            },
                            "pathScope": {
                              "additionalProperties": false,
                              "type": "object",
                              "required": [
                                "field",
                                "prefix"
                              ],
                              "properties": {
                                "field": {
                                  "minLength": 1,
                                  "type": "string"
                                },
                                "prefix": {
                                  "minLength": 1,
                                  "pattern": "^/(?!.*/\\.\\.(?:/|$)).*$",
                                  "type": "string"
                                }
                              }
                            },
                            "quotas": {
                              "type": "array",
                              "items": {
                                "additionalProperties": false,
                                "type": "object",
                                "required": [
                                  "key",
                                  "max",
                                  "window"
                                ],
                                "properties": {
                                  "key": {
                                    "minLength": 1,
                                    "type": "string"
                                  },
                                  "field": {
                                    "minLength": 1,
                                    "type": "string"
                                  },
                                  "max": {
                                    "minimum": 0,
                                    "type": "number"
                                  },
                                  "window": {
                                    "anyOf": [
                                      {
                                        "type": "string",
                                        "enum": [
                                          "session"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "day"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "week"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "month"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "lifetime"
                                        ]
                                      }
                                    ]
                                  }
                                }
                              }
                            }
                          }
                        },
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
